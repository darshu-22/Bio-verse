{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/server.js"
    },
    {
      "source": "/models/:path*",
      "destination": "/server.js"
    },
    {
      "source": "/((?!css|js|data|favicon\\.ico|.*\\.(?:css|js|json|png|jpg|jpeg|svg|ico|webp|glb)).*)",
      "destination": "/index.html"
    }
  ]
}
